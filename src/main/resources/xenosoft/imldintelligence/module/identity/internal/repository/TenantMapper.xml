<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="xenosoft.imldintelligence.module.identity.internal.repository.mybatis.TenantMapper">

    <sql id="BaseColumns">
        id,
        tenant_code,
        tenant_name,
        deploy_mode,
        status,
        created_at,
        updated_at
    </sql>

    <resultMap id="TenantResultMap" type="xenosoft.imldintelligence.module.identity.internal.model.Tenant">
        <id property="id" column="id"/>
        <result property="tenantCode" column="tenant_code"/>
        <result property="tenantName" column="tenant_name"/>
        <result property="deployMode" column="deploy_mode"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="TenantResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM tenant
        WHERE id = #{id}
    </select>

    <select id="findByTenantCode" resultMap="TenantResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM tenant
        WHERE tenant_code = #{tenantCode}
    </select>

    <select id="listAll" resultMap="TenantResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM tenant
        ORDER BY id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tenant (
            tenant_code,
            tenant_name,
            deploy_mode,
            status
        ) VALUES (
            #{tenantCode},
            #{tenantName},
            #{deployMode},
            #{status}
        )
    </insert>

    <update id="update">
        UPDATE tenant
        SET tenant_code = #{tenantCode},
            tenant_name = #{tenantName},
            deploy_mode = #{deployMode},
            status = #{status},
            updated_at = now()
        WHERE id = #{id}
    </update>

    <update id="deleteById">
        UPDATE tenant
        SET status = 'INACTIVE',
            updated_at = now()
        WHERE id = #{id}
    </update>

</mapper>
