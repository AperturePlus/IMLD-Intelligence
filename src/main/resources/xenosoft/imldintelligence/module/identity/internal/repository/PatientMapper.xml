<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="xenosoft.imldintelligence.module.identity.internal.repository.PatientMapper">
    <resultMap id="PatientResultMap" type="xenosoft.imldintelligence.module.identity.internal.model.Patient">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="patientNo" column="patient_no"/>
        <result property="patientName" column="patient_name"/>
        <result property="gender" column="gender"/>
        <result property="birthDate" column="birth_date"/>
        <result property="idNoEncrypted" column="id_no_encrypted"/>
        <result property="mobileEncrypted" column="mobile_encrypted"/>
        <result property="patientType" column="patient_type"/>
        <result property="status" column="status"/>
        <result property="sourceChannel" column="source_channel"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>


    <select id="findById" resultMap="PatientResultMap">
        SELECT * FROM patient
                 WHERE id = #{id}
                   AND tenant_id = #{tenantId}
    </select>





</mapper>
<!--
/**
 * Schema:
 * CREATE TABLE patient (
 *     id                      BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
 *     tenant_id               BIGINT NOT NULL REFERENCES tenant(id),
 *     patient_no              VARCHAR(64) NOT NULL,
 *     patient_name            VARCHAR(100) NOT NULL,
 *     gender                  VARCHAR(16),
 *     birth_date              DATE,
 *     id_no_encrypted         VARCHAR(255),
 *     mobile_encrypted        VARCHAR(255),
 *     patient_type            VARCHAR(32) NOT NULL,
 *     status                  VARCHAR(32) NOT NULL DEFAULT 'ACTIVE',
 *     source_channel          VARCHAR(32) NOT NULL DEFAULT 'HOSPITAL',
 *     created_at              TIMESTAMPTZ NOT NULL DEFAULT now(),
 *     updated_at              TIMESTAMPTZ NOT NULL DEFAULT now(),
 *     UNIQUE (tenant_id, patient_no)
 * );
 */
-->