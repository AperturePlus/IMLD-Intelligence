{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo", // TypeScript 增量编译的缓存文件，加快编译速度，便于热更新
    "target": "ES2023", // 编译后的 JavaScript 代码采用 ES2023 标准，支持最新语法
    "lib": ["ES2023"], // 编译时包含 ES2023 的标准库，提供最新 JS API 类型
    "module": "ESNext", // 采用 ESNext 模块系统，支持 import/export 的最新写法
    "skipLibCheck": true, // 跳过第三方库的类型检查，提升编译速度，减少类型冲突

    /* Bundler mode */
    "moduleResolution": "bundler", // 按打包工具（如 Vite、Webpack）方式解析模块路径
    "allowImportingTsExtensions": true, // 允许导入 .ts 文件扩展名（如 import x from './foo.ts'）
    "verbatimModuleSyntax": true, // 保留原始的 import/export 语法，不做自动转换
    "moduleDetection": "force", // 强制所有文件都按模块处理（即使没有 import/export 也视为模块）
    "noEmit": true, // 不生成编译后的 JS 文件，只做类型检查

    /* Linting */
    "strict": true, // 开启严格类型检查，提升代码安全性
    "noUnusedLocals": true, // 禁止未使用的局部变量，避免冗余代码
    "noUnusedParameters": true, // 禁止未使用的函数参数，提升代码质量
    "noFallthroughCasesInSwitch": true, // 防止 switch 语句 case 穿透，减少逻辑错误
    "noUncheckedSideEffectImports": true // 防止未检查副作用的导入，提高安全性
  },
  "include": ["vite.config.ts"] // 只检查 vite.config.ts 这个配置文件
}